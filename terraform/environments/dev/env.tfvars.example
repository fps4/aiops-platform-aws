# Central account ID (placeholder - update with actual account ID)
central_account_id = "123456789012"

# Subnets for Fargate statistical detection task
# aws ec2 describe-subnets --filters "Name=vpc-id,Values=<vpc-id>" "Name=defaultForAz,Values=true" --query 'Subnets[*].SubnetId'
