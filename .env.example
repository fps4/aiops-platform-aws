# AIOps Platform - Local Development Configuration
# Copy this file to .env and update with your values

# AWS Configuration
AWS_REGION=eu-central-1
AWS_PROFILE=default
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key

# Environment
ENVIRONMENT=dev
PROJECT_PREFIX=aiops-platform

# Bedrock Configuration
BEDROCK_REGION=eu-central-1
BEDROCK_RCA_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_CORRELATION_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0
BEDROCK_REMEDIATION_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_MAX_TOKENS=4096
BEDROCK_TEMPERATURE=0.7

# Data Store Resources (populated after terraform apply)
DYNAMODB_ANOMALIES_TABLE=aiops-platform-dev-anomalies
DYNAMODB_EVENTS_TABLE=aiops-platform-dev-events
DYNAMODB_POLICY_STORE_TABLE=aiops-platform-dev-policy-store
DYNAMODB_AGENT_STATE_TABLE=aiops-platform-dev-agent-state

S3_RAW_LOGS_BUCKET=aiops-platform-dev-raw-logs
S3_AUDIT_LOGS_BUCKET=aiops-platform-dev-audit-logs
S3_SCREENSHOTS_BUCKET=aiops-platform-dev-dashboard-screenshots

OPENSEARCH_ENDPOINT=https://your-collection-id.eu-central-1.aoss.amazonaws.com

# Slack Configuration (optional for local testing)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Local Development Settings
LOG_LEVEL=DEBUG
ENABLE_TRACING=true
DRY_RUN=false
